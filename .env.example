# Anthropic API key (server-side only, never exposed to the client)
ANTHROPIC_API_KEY=sk-ant-...

# Secret for internal/batch audits (bypasses rate limit) and /api/stats access
INTERNAL_KEY=change-me

# Where JSONL logs (leads, audits, events) are written. Mount a volume here in prod.
# DATA_DIR=/app/data

# Photoroom referral link for the result CTA (falls back to photoroom.com)
NEXT_PUBLIC_PHOTOROOM_URL=https://www.photoroom.com

# Optional PostHog analytics (EU cloud). Leave unset to disable.
# NEXT_PUBLIC_POSTHOG_KEY=phc_...

# Resend: full-report emails from the gate. Unset = capture-only (no send).
# Verify a SUBDOMAIN in Resend (e.g. send.pablo.ky), not the root domain.
# RESEND_API_KEY=re_...
# RESEND_FROM=Pablo from PhotoScore <reports@send.pablo.ky>
# RESEND_REPLY_TO=your@gmail.com
# PUBLIC_BASE_URL=https://photoscore.pablo.ky
